# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/.playwright

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/.npm-cache
/.claude/settings.local.json
/.claude/worktrees/
/.claude/agent-memory/pentest-specialist/
/.recovery/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# tauri
/src-tauri/target

# Server bundle (populated by prepare-standalone.mjs before tauri build)
/src-tauri/server/*
!/src-tauri/server/placeholder.txt

# scraper job output (per-job CSV/log files)
/scraper-output

# Superpowers brainstorm runtime state (mockups + scratch HTML, not source)
.superpowers/**/state/
.superpowers/**/content/

# Superpowers-generated planning/spec docs
/docs/superpowers/

# Visual Studio local state
/.vs/

# Vendored built-in skills (not project-specific; project agents live in .claude/agents/)
/.agents/skills/neon-postgres/
/.claude/skills/neon-postgres/
