{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCRM",
  "version": "0.1.0",
  "identifier": "com.opencrm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build && node scripts/prepare-standalone.mjs",
    "frontendDist": "frontend-placeholder"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenCRM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "server/**/*": "server"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
