generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 UserRole             @default(USER)
  // Platform-level "master account" flag, orthogonal to the org-scoped `role`.
  // When true, the user can read across every organization via the read-only
  // `platform` router (super-admin monitoring console). Never granted through
  // the app UI — set out-of-band via `scripts/grant-superadmin.ts`.
  isSuperAdmin         Boolean              @default(false)
  loadingAnimationMode LoadingAnimationMode @default(ALWAYS)
  // Bumped whenever credentials change (password reset / email change) so
  // JWTs minted before the change are rejected on their next refresh (CWE-613).
  sessionVersion       Int                  @default(0)
  accounts             Account[]
  sessions             Session[]

  // Organization Context
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  ledTeams Team[] @relation("TeamLeader")

  passwordResetTokens PasswordResetToken[]

  leads            Lead[]               @relation("AssignedTo")
  calls            CallLog[]
  notes            Note[]
  tasks            Task[]               @relation("TaskCreator")
  assignedTasks    Task[]               @relation("TaskAssignee")
  activities       Activity[]
  scraperJobs      ScraperJob[]
  scraperRows      ScraperImportedRow[]
  invitationsSent  Invitation[]         @relation("InvitationInviter")
  trainingSessions TrainingSession[]
  outreachJobs     OutreachJob[]
  conversationsAsUserA Conversation[]   @relation("ConversationUserA")
  conversationsAsUserB Conversation[]   @relation("ConversationUserB")
  messagesSent         Message[]        @relation("MessageSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum LoadingAnimationMode {
  ALWAYS
  ONCE_DAILY
  OFF
}

model Organization {
  id             String               @id @default(cuid())
  name           String
  users          User[]
  teams          Team[]
  leads          Lead[]
  notes          Note[]
  activities     Activity[]
  scraperJobs    ScraperJob[]
  scraperRows    ScraperImportedRow[]
  tasks          Task[]
  customOutcomes CustomOutcome[]
  scoringRules   ScoringRule[]
  leadTags       LeadTag[]
  invitations    Invitation[]
  pipelines      Pipeline[]

  scraperCategories OrgScraperCategory[]
  scheduledScrapes  ScheduledScrape[]
  emailDrafts       EmailDraft[]
  emailOptOuts      EmailOptOut[]
  smsDrafts         SmsDraft[]
  phoneOptOuts      PhoneOptOut[]
  salesScripts      SalesScript[]
  outreachJobs      OutreachJob[]

  trainingPersonas TrainingPersona[]
  trainingSessions TrainingSession[]
  conversations    Conversation[]

  subscription OrganizationSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum PlanTier {
  STARTER
  PRO
  BUSINESS
}

model OrganizationSubscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  planTier             PlanTier           @default(STARTER)
  status               SubscriptionStatus @default(TRIALING)
  seatLimit            Int                @default(3)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model StripeWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  createdAt DateTime @default(now())
}

model Team {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  users          User[]

  leaderId String?
  leader   User?   @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)

  invitations Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Lead {
  id                  String                   @id @default(cuid())
  firstName           String?
  lastName            String?
  email               String?
  phone               String?
  company             String?
  city                String?
  state               String?
  title               String?
  website             String?
  mapsUrl             String?
  latitude            Float?
  longitude           Float?
  rating              Float?
  reviewCount         Int?
  status              LeadStatus               @default(NOT_CONTACTED)
  temperatureOverride LeadTemperatureOverride?
  source              String?
  // Business niche (e.g. "Landscaping") — picks the demo Template Pack.
  // Provenance stays in `source`; do not pack category into it.
  category            String?
  value               Float?
  callOutcome         CallOutcome              @default(NOT_CONTACTED)
  callNotes           String?
  starred             Boolean                  @default(false)
  touchCount          Int                      @default(0)
  lastTouchedAt       DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  customOutcomeId String?
  customOutcome   CustomOutcome? @relation("PrimaryOutcome", fields: [customOutcomeId], references: [id], onDelete: SetNull)

  secondaryOutcomeId String?
  secondaryOutcome   CustomOutcome? @relation("SecondaryOutcome", fields: [secondaryOutcomeId], references: [id], onDelete: SetNull)

  pipelineStageId      String?
  pipelineStage        PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  qualificationSummary String?

  calls            CallLog[]
  notes            Note[]
  activities       Activity[]
  tasks            Task[]
  tags             LeadTag[]
  websites         GeneratedWebsite[]
  emailDrafts      EmailDraft[]
  smsDrafts        SmsDraft[]
  trainingSessions TrainingSession[]
  outreachJob      OutreachJob?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  // Importer uses (organizationId, company, phone) to dedup incoming CSV
  // rows against existing leads with a single bounded query.
  @@index([organizationId, company, phone])
  // Lead scope filtering for non-admins (assignedToId IN (...)).
  @@index([organizationId, assignedToId])
  @@index([organizationId, state, city])
  @@index([organizationId, lastTouchedAt])
  // Map viewport queries (leads inside a lat/lng bounding box).
  @@index([organizationId, latitude, longitude])
}

enum LeadStatus {
  NOT_CONTACTED
  CONNECTED
  AI_VOICEMAIL
  NO_ANSWER
  HUNG_UP
}

enum LeadTemperatureOverride {
  HOT
  WARM
  COOL
}

model LeadTag {
  id     String @id @default(cuid())
  name   String
  tagKey String
  leads  Lead[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@unique([organizationId, tagKey])
}

model Pipeline {
  id             String          @id @default(cuid())
  name           String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  stages         PipelineStage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  leads      Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallLog {
  id     String  @id @default(cuid())
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  duration     Int?
  status       CallStatus
  recordingUrl String?

  twilioCallSid String? @unique

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
  // Dashboard "calls today by user" and per-day rollups.
  @@index([userId, createdAt])
  @@index([leadId, createdAt])
}

enum CallStatus {
  BUSY
  NO_ANSWER
  CONNECTED
  FAILED
  CANCELED
}

enum CallOutcome {
  NOT_CONTACTED
  ANSWERED
  HUNG_UP
  NO_ANSWER
  AI_VOICEMAIL
  CUSTOM
}

model CustomOutcome {
  id             String       @id @default(cuid())
  label          String       @db.VarChar(80)
  hint           String?      @db.VarChar(200)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryLeads   Lead[]       @relation("PrimaryOutcome")
  secondaryLeads Lead[]       @relation("SecondaryOutcome")

  createdAt DateTime @default(now())

  @@index([organizationId])
}

model Note {
  id      String @id @default(cuid())
  content String
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Denormalized from Lead.organizationId so org-wide queries can hit a
  // covering index instead of joining through Lead. Nullable for now because
  // this column was added to an existing table — new rows always populate it
  // and `scripts/backfill-org-id.ts` fills in legacy rows. After backfill
  // verification, a follow-up should change this to required.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([organizationId, createdAt])
}

enum ActivityType {
  LEAD_CREATED
  LEAD_ASSIGNED
  LEAD_DELETED
  CALL_OUTCOME
  CALL_LOGGED
  LEAD_TEMPERATURE_OVERRIDE
  LEAD_VALUE_UPDATED
  LEAD_QUALIFIED
  TASK_CREATED
  TASK_COMPLETED
  NOTE_ADDED
  NOTE_DELETED
  EMAIL_DRAFT_CREATED
  EMAIL_SENT
  DEMO_GENERATED
  LEAD_ENRICHED
  // Declared last to match the DB: ALTER TYPE ... ADD VALUE (20260713060000)
  // appends to the end of the Postgres enum, and drift checks compare order.
  SMS_DRAFT_CREATED
  SMS_SENT
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String

  // Structured call outcome for CALL_OUTCOME activities (a "Touch" when not
  // NOT_CONTACTED). Null for other activity types. Source of all "Calls"
  // metrics — see docs/adr/0002-call-metrics-from-activity-touches.md.
  outcome CallOutcome?
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Denormalized from Lead.organizationId so org-wide activity feeds (team
  // activityFeed, dashboard "last active") avoid a join through Lead.
  // Nullable for now — see note on Note.organizationId.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([organizationId, createdAt])
  // Touch aggregations: "Calls" metrics filter by (org, type, createdAt) —
  // see docs/adr/0002-call-metrics-from-activity-touches.md.
  @@index([organizationId, type, createdAt])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  deletedAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TaskCreator", fields: [userId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([userId, dueDate])
  @@index([assignedToId, dueDate])
  @@index([organizationId, dueDate])
  @@index([organizationId, status])
  @@index([deletedAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  // SHA-256 hex of the raw token. The raw value is only ever emailed to the
  // user; a DB leak yields hashes that can't be reused.
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Email-token invitation flow. An admin invites by email; the recipient gets
// a one-time link to set their own password. The DB only ever stores the
// SHA-256 hash of the raw token, so a DB leak alone can't be used to claim
// pending invitations.
model Invitation {
  id             String           @id @default(cuid())
  tokenHash      String           @unique
  email          String
  name           String?
  role           UserRole         @default(USER)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId         String?
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedById    String?
  invitedBy      User?            @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  status         InvitationStatus @default(PENDING)
  expires        DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())

  @@index([organizationId, status])
  @@index([email])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// ─────────────────────────────────────────────────────────────────────────────
// Scraper feature
// ─────────────────────────────────────────────────────────────────────────────
model ScraperJob {
  id      String           @id @default(cuid())
  status  ScraperJobStatus @default(PENDING)
  // "SCRAPE" (location/category scrape) or "ENRICH" (map-selected lead enrichment)
  jobType String           @default("SCRAPE")

  locations  Json @default("[]")
  categories Json @default("[]")

  limit       Int @default(20)
  concurrency Int @default(1)

  totalScraped     Int     @default(0)
  importedCount    Int     @default(0)
  autoImport       Boolean @default(true)
  autoOutreach     Boolean @default(false)
  totalQueries     Int     @default(0)
  completedQueries Int     @default(0)
  failedQueries    Int     @default(0)

  outputDir       String?
  logs            String    @default("")
  error           String?
  workerId        String?
  workerPid       Int?
  lastHeartbeatAt DateTime?
  stopRequestedAt DateTime?

  startedAt   DateTime?
  completedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  importedRows ScraperImportedRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([status, lastHeartbeatAt])
  @@index([workerId])
}

model ScraperImportedRow {
  id          String     @id @default(cuid())
  jobId       String
  job         ScraperJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fingerprint String
  sourceUrl   String?
  leadId      String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  importedById String
  importedBy   User   @relation(fields: [importedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([jobId, fingerprint])
  @@index([organizationId, createdAt])
  @@index([sourceUrl])
}

enum ScraperJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  STOPPED
}

model ScoringRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  factor         String
  label          String
  maxPoints      Float        @default(25)
  weight         Float        @default(1.0)
  config         Json?
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model GeneratedWebsite {
  id             String       @id @default(cuid())
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template       String
  title          String
  content        Json
  slug           String?      @unique
  organizationId String?
  emailDrafts    EmailDraft[]
  smsDrafts      SmsDraft[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([leadId])
  @@index([organizationId])
}

model OrgScraperCategory {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
}

model ScheduledScrape {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations      Json         @default("[]")
  categories     Json         @default("[]")
  limit          Int          @default(20)
  concurrency    Int          @default(1)
  dayOfWeek      Int // 0=Sunday … 6=Saturday
  hourOfDay      Int // 0-23 UTC
  enabled        Boolean      @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  autoImport     Boolean      @default(true)
  autoOutreach   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([enabled, nextRunAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Email outreach feature
// ─────────────────────────────────────────────────────────────────────────────

enum EmailDraftStatus {
  DRAFT
  SENT
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
}

model EmailDraft {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId           String
  lead             Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  websiteId        String?
  website          GeneratedWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  subject          String
  body             String            @db.Text
  status           EmailDraftStatus  @default(DRAFT)
  unsubscribeToken String            @unique
  resendMessageId  String?
  sentAt           DateTime?
  events           EmailEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([leadId])
  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([resendMessageId])
}

model EmailEvent {
  id        String     @id @default(cuid())
  draftId   String
  draft     EmailDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  event     String
  // Svix message id from the delivering webhook. Used to deduplicate
  // at-least-once retries so a redelivered event doesn't append a duplicate
  // audit row. Nullable for events recorded outside the webhook path.
  svixId    String?    @unique
  data      Json?
  createdAt DateTime   @default(now())

  @@index([draftId, createdAt])
}

model EmailOptOut {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([email, organizationId])
  @@index([organizationId])
}

// SMS outreach is intentionally parallel to email outreach. Keeping separate
// lifecycle models avoids a channel-polymorphic draft whose fields and status
// rules would be mostly nullable.
enum SmsDraftStatus {
  DRAFT
  // Kept from the one-off SMS iteration (20260713060000): Postgres enum values
  // cannot be dropped in place. Unused by the outreach send flow.
  SENDING
  SENT
  DELIVERED
  FAILED
}

model SmsDraft {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId           String
  lead             Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  websiteId        String?
  website          GeneratedWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  toPhone          String
  body             String            @db.Text
  status           SmsDraftStatus    @default(DRAFT)
  twilioMessageSid String?           @unique
  sentAt           DateTime?
  events           SmsEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // At most one DRAFT row per lead — enforced by the partial unique index
  // "SmsDraft_leadId_active_draft_key" in the migration SQL (Prisma cannot
  // express partial indexes declaratively).
  @@index([leadId])
  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([toPhone])
}

model SmsEvent {
  id        String   @id @default(cuid())
  draftId   String
  draft     SmsDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  event     String
  dedupKey  String?  @unique
  data      Json?
  createdAt DateTime @default(now())

  @@index([draftId, createdAt])
}

model PhoneOptOut {
  id             String       @id @default(cuid())
  phone          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([phone, organizationId])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Automated outreach pipeline
// ─────────────────────────────────────────────────────────────────────────────

enum OutreachJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SKIPPED
}

model OutreachJob {
  id             String            @id @default(cuid())
  // One job per lead, ever — makes enqueueing idempotent across re-imports.
  leadId         String            @unique
  lead           Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Generated drafts/activities are attributed to this user.
  createdById    String
  createdBy      User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  status         OutreachJobStatus @default(PENDING)
  attempts       Int               @default(0)
  error          String?
  skipReason     String? // no_contact | phone_opted_out | sms_not_configured | opted_out | draft_exists | lead_deleted
  websiteId      String?
  draftId        String?
  smsDraftId     String?
  processedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([organizationId, status])
}

model SalesScript {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       String
  title          String
  body           String       @db.Text
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Voice call trainer feature
// ─────────────────────────────────────────────────────────────────────────────

model TrainingPersona {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String
  systemPrompt   String            @db.Text
  firstMessage   String
  voiceId        String
  voiceName      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  sessions       TrainingSession[]

  @@index([organizationId])
}

model TrainingSession {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId          String
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  personaId       String?
  persona         TrainingPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  transcript      Json
  scorecard       Json?
  durationSeconds Int?
  createdAt       DateTime         @default(now())

  @@index([organizationId, userId])
  @@index([organizationId, createdAt])
  @@index([leadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Team messaging feature
// ─────────────────────────────────────────────────────────────────────────────

// 1:1 conversation between two members of the same organization. The pair is
// stored in canonical order (userAId < userBId lexicographically) so the
// unique index guarantees exactly one conversation per pair. The ordering is
// also enforced by the check constraint
// "Conversation_canonical_participants_check" in the migration SQL (Prisma
// cannot express check constraints declaratively).
model Conversation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userAId String
  userA   User   @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId String
  userB   User   @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  // Denormalized timestamp of the newest message for conversation-list ordering.
  lastMessageAt DateTime?

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userAId, userBId])
  @@index([organizationId, lastMessageAt])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  // Read receipt for the non-sender participant (conversations are 1:1).
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
}
