# ============================================
# REQUIRED CONFIGURATION
# ============================================

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-generated-secret-here"
# IMPORTANT: Set this to the URL users access your app from.
# For Docker on a server, use: http://your-server-ip:3000 or https://your-domain.com
# Using http:// is fine — it controls cookie security flags (Secure, __Secure- prefix).
NEXTAUTH_URL="http://localhost:3000"

# Application Environment
NODE_ENV="production"

# ============================================
# DOCKER / DATABASE CONFIGURATION
# ============================================

# PostgreSQL credentials (used by docker-compose for both the db service and the app)
POSTGRES_USER="crm"
POSTGRES_PASSWORD="change-me-strong-password-here"
POSTGRES_DB="crm"

# Full connection string — must match the values above
DATABASE_URL="postgresql://crm:change-me-strong-password-here@db:5432/crm"

# For local development outside Docker, point to localhost instead:
# DATABASE_URL="postgresql://crm:change-me-strong-password-here@localhost:5432/crm"

# ============================================
# OPTIONAL: Authentication Providers
# ============================================

# Google OAuth
# Setup: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# ============================================
# OPTIONAL: Phone/Calling Features (Twilio)
# ============================================

# Twilio - for integrated calling and SMS
# Setup: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+1234567890"

# ============================================
# OPTIONAL: Email / Password Reset (SMTP)
# ============================================

# Required for sending password-reset emails.
# Without these, reset links are logged to the server console (dev-friendly).
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"          # set "true" for port 465 / TLS
# SMTP_USER="you@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="OpenCRM <noreply@example.com>"

# ============================================
# OPTIONAL: AI Features (OpenAI)
# ============================================

# OpenAI - for AI-powered analytics and suggestions
# OPENAI_API_KEY="sk-..."

# ============================================
# OPTIONAL: File Storage (AWS S3)
# ============================================

# AWS S3 - for storing documents and files
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET_NAME="..."

# ============================================
# OPTIONAL: Caching + Rate Limiting (Redis)
# ============================================

# Redis is used for the auth-session snapshot cache (so deleted/role-changed
# users are revoked within ~60s) and for rate limiting public auth endpoints
# (signin, register, password reset). When REDIS_URL is unset or Redis is
# unreachable, both subsystems fail open with a warning logged to stderr.
# REDIS_URL="redis://localhost:6379"

# ============================================
# OPTIONAL: Reverse-proxy IP forwarding
# ============================================

# Set to "true" when the app sits behind a trusted reverse proxy (e.g.
# nginx, AWS ALB, Cloudflare) that sets x-forwarded-for. Without this,
# x-forwarded-for is ignored to prevent IP spoofing in rate-limit keys.
# TRUSTED_PROXY="false"
