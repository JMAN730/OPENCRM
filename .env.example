# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Database
# PostgreSQL connection string (e.g., from Supabase, Railway, Neon, or local)
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/crm_db?schema=public"

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Application Environment
NODE_ENV="development"

# ============================================
# OPTIONAL: Authentication Providers
# ============================================

# Google OAuth
# Setup: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# ============================================
# OPTIONAL: Phone/Calling Features (Twilio)
# ============================================

# Twilio - for integrated calling and SMS
# Setup: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+1234567890"

# ============================================
# OPTIONAL: AI Features (OpenAI)
# ============================================

# OpenAI - for AI-powered analytics and suggestions
# Get API key: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# ============================================
# OPTIONAL: File Storage (AWS S3)
# ============================================

# AWS S3 - for storing documents and files
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET_NAME="..."

# ============================================
# OPTIONAL: Caching (Redis)
# ============================================

# Redis - for session caching and real-time features
# REDIS_URL="redis://localhost:6379"
