# Required
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="production"

# PostgreSQL
POSTGRES_USER="crm"
POSTGRES_PASSWORD="change-me-strong-password-here"
POSTGRES_DB="crm"
DATABASE_URL="postgresql://crm:change-me-strong-password-here@db:5432/crm"

# Local development alternative
# DATABASE_URL="postgresql://crm:change-me-strong-password-here@localhost:5432/crm"

# Optional: Google OAuth
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Optional: SMTP for password-reset emails.
# Without these, reset links are logged to the server console.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="you@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="OpenCRM <noreply@example.com>"

# Optional: Twilio (required for the browser dialer at /dialer)
# 1. Create a Twilio account and buy a phone number
# 2. Create a TwiML App pointing to https://<your-domain>/api/twilio/voice
# 3. Create an API Key/Secret pair (use these instead of Account SID/Auth Token for tokens)
# 4. In local dev: expose via `ngrok http 3000` and use the ngrok URL for the TwiML App webhook
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_API_KEY="SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_API_SECRET="your-api-secret"
# TWILIO_TWIML_APP_SID="APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_PHONE_NUMBER="+15551234567"
# TWILIO_AUTH_TOKEN="your-account-auth-token"   # Required for webhook signature validation

# Optional: Redis for rate limiting and auth-session cache invalidation
# REDIS_URL="redis://localhost:6379"

# Optional – Cron endpoint authentication (required to use /api/cron/scraper)
# CRON_SECRET="generate-with: openssl rand -hex 32"

# Optional: DeepSeek — used for AI lead qualification, demo sites, and email drafts
# DEEPSEEK_API_KEY="sk-..."
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# AI_MODEL="deepseek-chat"

# Optional: Google Places API — enables real business photos on AI demo sites
# Without this, demo sites fall back to a Google Maps iframe embed (if mapsUrl exists)
# or ask Opulence to collect photos from the user.
# GOOGLE_PLACES_API_KEY="AIza..."

# Optional: Resend — required for outreach email sending
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="outreach@yourdomain.com"   # Must be a verified Resend sender
# RESEND_WEBHOOK_SECRET="whsec_..."             # From Resend dashboard → Webhooks

# Optional: CAN-SPAM sender identity (required when sending outreach emails)
# SENDER_NAME="Your Name"
# SENDER_PHYSICAL_ADDRESS="123 Main St, City, ST 00000"

# Optional: Public app URL — used for demo site links and email tracking/unsubscribe URLs
# Required for /demo/[slug], /t/[emailId], and /unsubscribe/[token] to generate correct links
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: built-in Traefik reverse proxy for bare-server deployments.
# It is disabled by default; start it with `docker compose --profile proxy up --build -d`.
# Hosted platforms that already provide a reverse proxy should leave this disabled.
# APP_DOMAIN="crm.example.com"
# ACME_EMAIL="admin@example.com"
# TRAEFIK_HTTP_PORT="80"
# TRAEFIK_HTTPS_PORT="443"

# Reverse proxy IP forwarding (IMPORTANT for rate limiting correctness)
# Set to "true" when running behind Nginx, Caddy, or any load balancer that
# sets x-forwarded-for. Without this, rate limiting falls back to x-real-ip;
# if neither header is present, all clients share one bucket.
# TRUSTED_PROXY="true"
