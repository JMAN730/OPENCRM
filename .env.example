# Required
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="production"

# PostgreSQL
POSTGRES_USER="crm"
POSTGRES_PASSWORD="change-me-strong-password-here"
POSTGRES_DB="crm"
DATABASE_URL="postgresql://crm:change-me-strong-password-here@db:5432/crm"

# Local development alternative
# DATABASE_URL="postgresql://crm:change-me-strong-password-here@localhost:5432/crm"

# --- Supabase (managed Postgres) ---
# Supabase requires TLS, so keep the ?sslmode=require suffix. If cert
# verification fails in your environment, use ?sslmode=no-verify instead.
#
# Runtime connection — session pooler (IPv4, supports prepared statements,
# ideal for a long-running server). Used by the app via @prisma/adapter-pg:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Migrations / `prisma db push` — direct connection (DDL needs a real session,
# not a pooler). If your environment lacks IPv6, point this at the session
# pooler too. Read by prisma.config.ts:
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Optional: Google OAuth
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Optional: SMTP for password-reset emails.
# Without these, reset links are logged to the server console.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="you@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="OpenCRM <noreply@example.com>"

# Optional: Twilio (required for the browser dialer at /dialer)
# 1. Create a Twilio account and buy a phone number
# 2. Create a TwiML App pointing to https://<your-domain>/api/twilio/voice
# 3. Create an API Key/Secret pair (use these instead of Account SID/Auth Token for tokens)
# 4. In local dev: expose via `ngrok http 3000` and use the ngrok URL for the TwiML App webhook
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_API_KEY="SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_API_SECRET="your-api-secret"
# TWILIO_TWIML_APP_SID="APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_PHONE_NUMBER="+15551234567"

# Optional: Redis for rate limiting and auth-session cache invalidation
# REDIS_URL="redis://localhost:6379"

# Reverse proxy IP forwarding (IMPORTANT for rate limiting correctness)
# Set to "true" when running behind Nginx, Caddy, or any load balancer that
# sets x-forwarded-for. Without this, rate limiting falls back to x-real-ip;
# if neither header is present, all clients share one bucket.
# TRUSTED_PROXY="true"
