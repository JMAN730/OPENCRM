# Required
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="production"

# PostgreSQL
POSTGRES_USER="crm"
POSTGRES_PASSWORD="change-me-strong-password-here"
POSTGRES_DB="crm"
DATABASE_URL="postgresql://crm:change-me-strong-password-here@db:5432/crm"

# Local development alternative
# DATABASE_URL="postgresql://crm:change-me-strong-password-here@localhost:5432/crm"

# Optional: Google OAuth
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Optional: SMTP for password-reset emails.
# Without these, reset links are logged to the server console.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="you@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="OpenCRM <noreply@example.com>"

# Optional: Redis for rate limiting and auth-session cache invalidation
# REDIS_URL="redis://localhost:6379"

# Reverse proxy IP forwarding (IMPORTANT for rate limiting correctness)
# Set to "true" when running behind Nginx, Caddy, or any load balancer that
# sets x-forwarded-for. Without this, rate limiting falls back to x-real-ip;
# if neither header is present, all clients share one bucket.
# TRUSTED_PROXY="true"
